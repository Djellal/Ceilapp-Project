@page "/add-compensation"
@attribute [Authorize]

<PageTitle>Ajouter une compensation</PageTitle>
    <RadzenColumn SizeMD=12>
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Impossible d'enregistrer la compensation</RadzenAlert>
        <RadzenTemplateForm TItem="Ceilapp.Models.ceilapp.Compensation" Data="@(compensation)" Visible="@(compensation != null)" Submit="@FormSubmit">
          <RadzenStack>
            <RadzenFormField Text="Inscription de l'étudiant" Variant="Variant.Filled">
                  <ChildContent>
                    <RadzenDropDown TValue="int" Data="@(registrationDisplayItems)" TextProperty="DisplayText" ValueProperty="Id"
                          AllowClear="true" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                          style="display: block; width: 100%" @bind-Value="@(compensation.CourseRegistrationId)" Name="CourseRegistrationId"
                          Placeholder="Rechercher un étudiant par nom, code ou cours..." />
              </ChildContent>
              <Helper>
                    <RadzenRequiredValidator Component="CourseRegistrationId" Text="L'inscription de l'étudiant est requise" DefaultValue="0" />
              </Helper>
            </RadzenFormField>
            <RadzenFormField Text="Date d'absence" Variant="Variant.Filled">
                  <ChildContent>
                    <RadzenDatePicker DateFormat="dd/MM/yyyy" style="display: block; width: 100%" @bind-Value="@(compensation.AbsenceDate)" Name="AbsenceDate" />
                  </ChildContent>    
                  <Helper>
                    <RadzenRequiredValidator Component="AbsenceDate" Text="La date d'absence est requise" />
                  </Helper>
            </RadzenFormField>
            <RadzenFormField Text="Heure début absence" Variant="Variant.Filled">
                  <ChildContent>
                    <RadzenMask CharacterPattern="[0-9]" Mask="**:**:**" Value="@(compensation.AbsenceFrom.ToString())" Change="@(args => { try { compensation.AbsenceFrom = TimeSpan.Parse(!string.IsNullOrEmpty(args) ? args : "00:00"); } catch{} })" style="display: block; width: 100%" Name="AbsenceFrom" />
                  </ChildContent>    
                  <Helper>
                    <RadzenRequiredValidator Component="AbsenceFrom" Text="L'heure de début d'absence est requise" />
                  </Helper>
            </RadzenFormField>
            <RadzenFormField Text="Heure fin absence" Variant="Variant.Filled">
                  <ChildContent>
                    <RadzenMask CharacterPattern="[0-9]" Mask="**:**:**" Value="@(compensation.AbsenceTo.ToString())" Change="@(args => { try { compensation.AbsenceTo = TimeSpan.Parse(!string.IsNullOrEmpty(args) ? args : "00:00"); } catch{} })" style="display: block; width: 100%" Name="AbsenceTo" />
                  </ChildContent>    
                  <Helper>
                    <RadzenRequiredValidator Component="AbsenceTo" Text="L'heure de fin d'absence est requise" />
                  </Helper>
            </RadzenFormField>
            <RadzenFormField Text="Date de rattrapage" Variant="Variant.Filled">
                  <ChildContent>
                    <RadzenDatePicker DateFormat="dd/MM/yyyy" style="display: block; width: 100%" @bind-Value="@(compensation.MakeupDate)" Name="MakeupDate" />
                  </ChildContent>    
                  <Helper>
                    <RadzenRequiredValidator Component="MakeupDate" Text="La date de rattrapage est requise" />
                  </Helper>
            </RadzenFormField>
            <RadzenFormField Text="Heure début rattrapage" Variant="Variant.Filled">
                  <ChildContent>
                    <RadzenMask CharacterPattern="[0-9]" Mask="**:**:**" Value="@(compensation.MakeupFrom.ToString())" Change="@(args => { try { compensation.MakeupFrom = TimeSpan.Parse(!string.IsNullOrEmpty(args) ? args : "00:00"); } catch{} })" style="display: block; width: 100%" Name="MakeupFrom" />
                  </ChildContent>    
                  <Helper>
                    <RadzenRequiredValidator Component="MakeupFrom" Text="L'heure de début de rattrapage est requise" />
                  </Helper>
            </RadzenFormField>
            <RadzenFormField Text="Heure fin rattrapage" Variant="Variant.Filled">
                  <ChildContent>
                    <RadzenMask CharacterPattern="[0-9]" Mask="**:**:**" Value="@(compensation.MakeupTo.ToString())" Change="@(args => { try { compensation.MakeupTo = TimeSpan.Parse(!string.IsNullOrEmpty(args) ? args : "00:00"); } catch{} })" style="display: block; width: 100%" Name="MakeupTo" />
                  </ChildContent>    
                  <Helper>
                    <RadzenRequiredValidator Component="MakeupTo" Text="L'heure de fin de rattrapage est requise" />
                  </Helper>
            </RadzenFormField>
            <RadzenFormField Text="Enseignant de rattrapage" Variant="Variant.Filled">
                  <ChildContent>
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@(compensation.MakeupTeacherId)" Name="MakeupTeacherId" MaxLength="100" />
                  </ChildContent>    
                  <Helper>
                    <RadzenRequiredValidator Component="MakeupTeacherId" Text="L'enseignant de rattrapage est requis" />
                  </Helper>
            </RadzenFormField>
          </RadzenStack>
          <RadzenStack style="margin-top:1rem;" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Enregistrer" Variant="Variant.Flat" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Annuler" Variant="Variant.Flat" Click="@CancelButtonClick"  />
          </RadzenStack>
        </RadzenTemplateForm>
    </RadzenColumn>
